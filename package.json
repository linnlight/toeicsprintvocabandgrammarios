{
  "name": "vocab-sprint",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.15",
    "expo-asset": "~56.0.17",
    "expo-audio": "~56.0.12",
    "expo-build-properties": "~56.0.22",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.15",
    "expo-notifications": "~56.0.20",
    "expo-router": "~56.2.14",
    "expo-speech": "~56.0.3",
    "expo-splash-screen": "~56.0.12",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-purchases": "10.4.0",
    "react-native-purchases-ui": "10.4.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "@vitest/coverage-v8": "^4.1.9",
    "csv-parse": "^7.0.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "node scripts/run-ios-simulator.mjs",
    "ios:device": "expo run:ios --device",
    "ios:patch": "node scripts/patch-ios-native.mjs",
    "ios:prepare": "expo prebuild --platform ios --no-install && node scripts/patch-ios-native.mjs && pod install --project-directory=ios",
    "web": "expo start --web",
    "check": "npm run typecheck && npm run lint && npm test && npm run content:validate",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "export:web": "expo export --platform web",
    "content:validate": "node scripts/import-vocabulary.mjs src/content/vocabulary.json --check && node scripts/import-vocabulary.mjs src/content/essential-vocabulary.json --check && node scripts/import-vocabulary.mjs src/content/topic-vocabulary.json --check && node scripts/audit-content.mjs",
    "content:clean": "node scripts/clean-vocabulary-content.mjs",
    "content:import": "node scripts/import-vocabulary.mjs"
  },
  "overrides": {
    "xcode": {
      "uuid": "^11.1.1"
    }
  },
  "private": true
}
